default_platform(:android)

platform :android do
  desc "Push the Play Store listing (text + graphics) without uploading a binary"
  lane :metadata do
    supply(
      package_name: "com.emon5122.linkvault",
      json_key: ENV["SUPPLY_JSON_KEY"] || "google-service-account.json",
      metadata_path: "./fastlane/metadata/android",
      skip_upload_apk: true,
      skip_upload_aab: true,
      skip_upload_metadata: false,
      # Changelogs are release-scoped (they attach to a specific version code on a track). This lane
      # pushes only the global store listing + graphics with no binary, so skip them — otherwise
      # supply fails with "Could not find release for version code '' to update changelog".
      skip_upload_changelogs: true,
      # Images upload only if present under en-US/images. Missing images are skipped, not an error.
      skip_upload_images: false,
      skip_upload_screenshots: false,
      # Point at the track that actually has a release (internal, version code 3). supply resolves a
      # release for changelog context even when uploading only listing/graphics; "production" has no
      # release yet, which caused "Could not find release for version code ''". The store listing +
      # screenshots are global (not track-scoped), so this only fixes release resolution.
      track: "internal",
      validate_only: false
    )
  end

  desc "Push the Play release notes for the release currently on a track"
  # Complement to `metadata`, which deliberately skips changelogs. This lane does the opposite:
  # changelogs only, no listing text, no graphics, no binary.
  #
  # It must run AFTER a build has been submitted, because supply attaches release notes to an
  # existing release on the track — with nothing there it fails with
  # "Could not find release for version code ''". The text comes from
  # fastlane/metadata/android/en-US/changelogs/default.txt, which `scripts/play-notes.js`
  # regenerates from CHANGELOG.md whenever release-please cuts a release.
  lane :release_notes do |options|
    supply(
      package_name: "com.emon5122.linkvault",
      json_key: ENV["SUPPLY_JSON_KEY"] || "google-service-account.json",
      metadata_path: "./fastlane/metadata/android",
      track: options[:track] || ENV["SUPPLY_TRACK"] || "internal",
      skip_upload_apk: true,
      skip_upload_aab: true,
      skip_upload_metadata: true,
      skip_upload_images: true,
      skip_upload_screenshots: true,
      skip_upload_changelogs: false,
      validate_only: false
    )
  end
end
