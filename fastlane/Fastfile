default_platform(:android)

platform :android do
  desc "Push the Play Store listing (text + graphics) without uploading a binary"
  lane :metadata do
    supply(
      package_name: "com.emon5122.linkvault",
      json_key: ENV["SUPPLY_JSON_KEY"] || "google-service-account.json",
      metadata_path: "./fastlane/metadata/android",
      skip_upload_apk: true,
      skip_upload_aab: true,
      skip_upload_metadata: false,
      skip_upload_changelogs: false,
      # Images upload only if present under en-US/images. Missing images are skipped, not an error.
      skip_upload_images: false,
      skip_upload_screenshots: false,
      track: "production",
      validate_only: false
    )
  end
end
