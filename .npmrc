# React Native's Android native build resolves C++ include paths through node_modules. pnpm's
# default isolated layout routes those through symlinks, which makes ninja fail with
# "manifest 'build.ninja' still dirty after 100 tries", and leaves transitive native modules
# (e.g. @react-native-masked-view/masked-view via @gorhom/bottom-sheet) off the root where
# Gradle autolinking expects them. Hoisting resolves both.
node-linker=hoisted
