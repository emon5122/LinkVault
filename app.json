{
  "expo": {
    "name": "LinkVault",
    "slug": "LinkVault",
    "owner": "emon5122",
    "version": "1.1.0",
    "orientation": "portrait",
    "icon": "./assets/images/icon.png",
    "scheme": "linkvault",
    "userInterfaceStyle": "automatic",
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.emon5122.linkvault"
    },
    "android": {
      "package": "com.emon5122.linkvault",
      "blockedPermissions": [
        "com.google.android.gms.permission.AD_ID",
        "android.permission.SYSTEM_ALERT_WINDOW",
        "android.permission.READ_EXTERNAL_STORAGE",
        "android.permission.WRITE_EXTERNAL_STORAGE"
      ],
      "adaptiveIcon": {
        "backgroundColor": "#2563eb",
        "foregroundImage": "./assets/images/android-icon-foreground.png",
        "backgroundImage": "./assets/images/android-icon-background.png",
        "monochromeImage": "./assets/images/android-icon-monochrome.png"
      },
      "predictiveBackGestureEnabled": false,
      "intentFilters": [
        {
          "action": "VIEW",
          "autoVerify": true,
          "data": [
            {
              "scheme": "https",
              "host": "linkvault.app",
              "pathPrefix": "/add"
            }
          ],
          "category": [
            "BROWSABLE",
            "DEFAULT"
          ]
        }
      ]
    },
    "web": {
      "output": "static",
      "bundler": "metro",
      "favicon": "./assets/images/favicon.png"
    },
    "plugins": [
      "expo-router",
      [
        "expo-splash-screen",
        {
          "backgroundColor": "#208AEF",
          "image": "./assets/images/splash-icon.png",
          "imageWidth": 76
        }
      ],
      "expo-sqlite",
      "expo-secure-store",
      "expo-sharing",
      [
        "expo-notifications",
        {
          "color": "#2563eb"
        }
      ],
      [
        "expo-web-browser",
        {
          "experimentalLauncherActivity": true
        }
      ],
      [
        "expo-camera",
        {
          "cameraPermission": "LinkVault uses the camera only to scan folder QR codes. Nothing is recorded or uploaded.",
          "recordAudioAndroid": false
        }
      ],
      [
        "expo-share-intent",
        {
          "androidIntentFilters": [
            "text/*"
          ],
          "androidMultiIntentFilters": [
            "text/*"
          ]
        }
      ]
    ],
    "experiments": {
      "typedRoutes": true,
      "reactCompiler": true
    },
    "extra": {
      "router": {},
      "eas": {
        "build": {
          "experimental": {
            "ios": {
              "appExtensions": [
                {
                  "targetName": "ShareExtension",
                  "bundleIdentifier": "com.emon5122.linkvault.share-extension",
                  "entitlements": {
                    "com.apple.security.application-groups": [
                      "group.com.emon5122.linkvault"
                    ]
                  }
                }
              ]
            }
          }
        },
        "projectId": "e3d716a5-0463-49a7-aba8-715263c61451"
      }
    }
  }
}
